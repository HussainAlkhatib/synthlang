{
  "scopeName": "source.synthlang",
  "name": "SynthLang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#macros" },
    { "include": "#ffi_imports" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.synthlang", "match": "#.*$" },
        { "name": "comment.line.double-slash.synthlang", "match": "//.*$" },
        { "name": "comment.block.synthlang", "begin": "/\\*", "end": "\\*/", "patterns": [] }
      ]
    },
    "macros": {
      "patterns": [
        { "name": "keyword.control.directive.synthlang", "match": "@[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    },
    "ffi_imports": {
      "patterns": [
        { "name": "keyword.control.import.synthlang", "match": "@(python|javascript|rust|c|go|java)\\s+module\\s+\"[^\"]*\"" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.synthlang", "match": "\\b(let|var|const|fn|if|elif|else|for|while|return|go|await|match|defer|try|handle|panic|in|as|and|or|not|module|import|export|class|struct|enum|type|impl|trait)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "support.type.synthlang", "match": "\\b(int|float|str|string|bool|void|list|dict|object|array|map|set|option|result|error|any)\\b" }
      ]
    },
    "literals": {
      "patterns": [
        { "name": "constant.language.synthlang", "match": "\\b(null|true|false)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.synthlang", "match": "(=|==|!=|<=|>=|<|>|\\+|-|\\*|/|%|&&|\\|\\||!|\\.|,|:|;|\\->|<-)" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.synthlang", "begin": "\"", "end": "\"", "patterns": [{ "include": "#escaped_characters" }] },
        { "name": "string.quoted.single.synthlang", "begin": "'", "end": "'", "patterns": [{ "include": "#escaped_characters" }] }
      ]
    },
    "escaped_characters": {
      "patterns": [
        { "name": "constant.character.escape.synthlang", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.integer.synthlang", "match": "\\b0[xX][0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.integer.synthlang", "match": "\\b-?[0-9]+\\b" },
        { "name": "constant.numeric.float.synthlang", "match": "\\b-?[0-9]+\\.[0-9]+\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.synthlang", "match": "\\bfn\\s+[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.other.synthlang", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b" }
      ]
    }
  },
  "fileTypes": ["sl"]
}