{
    "scopeName": "source.synthlang",
    "name": "SynthLang",
    "patterns": [{
        "include": "#comments"
    }, {
        "include": "#annotations"
    }, {
        "include": "#ffi_imports"
    }, {
        "include": "#keywords"
    }, {
        "include": "#operators"
    }, {
        "include": "#strings"
    }, {
        "include": "#numbers"
    }, {
        "include": "#booleans"
    }, {
        "include": "#types"
    }, {
        "include": "#functions"
    }],
    "repository": {
        "comments": {
            "patterns": [{
                "name": "comment.line.number-sign.synthlang",
                "match": "#.*$"
            }, {
                "name": "comment.line.double-slash.synthlang",
                "match": "//.*$"
            }, {
                "name": "comment.block.synthlang",
                "begin": "/\\*",
                "end": "\\*/"
            }]
        },
        "annotations": {
            "patterns": [{
                "name": "keyword.annotation.synthlang",
                "match": "@[a-zA-Z_][a-zA-Z0-9_-]*"
            }]
        },
        "ffi_imports": {
            "patterns": [{
                "name": "keyword.control.import.synthlang",
                "match": "@(?:python|javascript|rust|c|go|java)\\s+module\\s+\"[^\"]*\"\\s+(?:as|import)\\s+[a-zA-Z_][a-zA-Z0-9_, ]*"
            }]
        },
        "keywords": {
            "patterns": [{
                "name": "keyword.control.synthlang",
                "match": "\\b(?:let|var|fn|if|elif|else|for|while|return|go|await|try|handle|panic|defer|match|in|as|module)\\b"
            }]
        },
        "types": {
            "patterns": [{
                "name": "support.type.synthlang",
                "match": "\\b(?:int|float|str|string|bool|void|list|dict|object)\\b"
            }]
        },
        "booleans": {
            "patterns": [{
                "name": "constant.language.boolean.synthlang",
                "match": "\\b(?:true|false)\\b"
            }]
        },
        "operators": {
            "patterns": [{
                "name": "keyword.operator.synthlang",
                "match": "[+\\-*/<>!&%=\\[\\](){}|,.:;|\\?]"
            }]
        },
        "strings": {
            "patterns": [{
                "name": "string.quoted.double.synthlang",
                "begin": "\"",
                "end": "\"",
                "patterns": []
            }, {
                "name": "string.quoted.single.synthlang",
                "begin": "'",
                "end": "'",
                "patterns": []
            }]
        },
        "numbers": {
            "patterns": [{
                "name": "constant.numeric.integer.synthlang",
                "match": "\\b-?[0-9]+\\b"
            }, {
                "name": "constant.numeric.float.synthlang",
                "match": "\\b-?[0-9]+\\.[0-9]+\\b"
            }]
        },
        "functions": {
            "patterns": [{
                "name": "entity.name.function.synthlang",
                "match": "\\bfn\\s+[a-zA-Z_][a-zA-Z0-9_]*"
            }]
        }
    },
    "fileTypes": ["sl"]
}